  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "pg": "^8.13.0"
  },
  "peerDependencies": {
    "@zensation/core": "^0.2.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
