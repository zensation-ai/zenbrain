{
  "name": "@zensation/adapter-postgres",
  "version": "0.1.0",
  "description": "PostgreSQL + pgvector storage adapter for ZenBrain memory system.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
