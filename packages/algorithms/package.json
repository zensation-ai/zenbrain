      "import": "./dist/emotional.js",
      "require": "./dist/emotional.cjs"
    },
    "./context-retrieval": {
      "types": "./dist/context-retrieval.d.ts",
      "import": "./dist/context-retrieval.js",
      "require": "./dist/context-retrieval.cjs"
