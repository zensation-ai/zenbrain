      "types": "./dist/spectral-health.d.ts",
      "import": "./dist/spectral-health.js",
      "require": "./dist/spectral-health.cjs"
    },
    "./ib-budget": {
      "types": "./dist/ib-budget.d.ts",
      "import": "./dist/ib-budget.js",
      "require": "./dist/ib-budget.cjs"
    },
    "./dopamine-routing": {
      "types": "./dist/dopamine-routing.d.ts",
