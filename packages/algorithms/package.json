      "types": "./dist/temporal-multi-route.d.ts",
      "import": "./dist/temporal-multi-route.js",
      "require": "./dist/temporal-multi-route.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
