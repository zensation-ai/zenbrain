{
  "name": "@zensation/algorithms",
  "version": "0.2.1",
  "description": "Neuroscience-inspired memory algorithms: FSRS spaced repetition, Hebbian learning, Ebbinghaus decay, emotional tagging, Bayesian confidence propagation. Zero dependencies.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./fsrs": {
      "types": "./dist/fsrs.d.ts",
      "import": "./dist/fsrs.js",
      "require": "./dist/fsrs.cjs"
    },
    "./ebbinghaus": {
      "types": "./dist/ebbinghaus.d.ts",
      "import": "./dist/ebbinghaus.js",
      "require": "./dist/ebbinghaus.cjs"
    },
    "./emotional": {
      "types": "./dist/emotional.d.ts",
      "import": "./dist/emotional.js",
      "require": "./dist/emotional.cjs"
    },
    "./context-retrieval": {
      "types": "./dist/context-retrieval.d.ts",
      "import": "./dist/context-retrieval.js",
      "require": "./dist/context-retrieval.cjs"
    },
    "./hebbian": {
      "types": "./dist/hebbian.d.ts",
      "import": "./dist/hebbian.js",
      "require": "./dist/hebbian.cjs"
    },
    "./bayesian": {
      "types": "./dist/bayesian.d.ts",
      "import": "./dist/bayesian.js",
      "require": "./dist/bayesian.cjs"
    },
    "./similarity": {
      "types": "./dist/similarity.d.ts",
      "import": "./dist/similarity.js",
      "require": "./dist/similarity.cjs"
    },
    "./intervals": {
      "types": "./dist/intervals.d.ts",
      "import": "./dist/intervals.js",
      "require": "./dist/intervals.cjs"
    },
    "./visualization": {
      "types": "./dist/visualization.d.ts",
      "import": "./dist/visualization.js",
      "require": "./dist/visualization.cjs"
    },
    "./sleep-consolidation": {
      "types": "./dist/sleep-consolidation.d.ts",
      "import": "./dist/sleep-consolidation.js",
      "require": "./dist/sleep-consolidation.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai-memory",
    "spaced-repetition",
    "fsrs",
    "ebbinghaus",
    "hebbian-learning",
    "emotional-memory",
    "bayesian",
    "knowledge-graph",
    "neuroscience",
    "ai-agents",
    "memory-system",
    "forgetting-curve",
    "context-dependent-retrieval"
  ],
  "author": "ZenSation <open-source@zensation.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/zensation-ai/zenbrain.git",
    "directory": "packages/algorithms"
  },
  "homepage": "https://github.com/zensation-ai/zenbrain/tree/main/packages/algorithms#readme",
  "bugs": {
    "url": "https://github.com/zensation-ai/zenbrain/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
