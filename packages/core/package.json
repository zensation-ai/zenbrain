{
  "name": "@zensation/core",
  "version": "0.1.0",
  "description": "7-layer memory system for AI agents. Pluggable storage, embeddings, and LLM providers. Built on @zensation/algorithms.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./interfaces": {
      "types": "./dist/interfaces/index.d.ts",
      "import": "./dist/interfaces/index.js"
    },
    "./layers/*": {
      "types": "./dist/layers/*.d.ts",
      "import": "./dist/layers/*.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai-memory",
    "memory-layers",
    "working-memory",
    "episodic-memory",
    "procedural-memory",
    "long-term-memory",
    "ai-agents",
    "neuroscience",
    "pluggable-adapters"
  ],
  "author": "ZenSation <open-source@zensation.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/zensation-ai/zenbrain.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/zensation-ai/zenbrain/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/zensation-ai/zenbrain/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@zensation/algorithms": "^0.1.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
